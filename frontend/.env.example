# Environment Configuration
# Copy this file to .env.local for local development
# Set these in Vercel dashboard for production

# Default network: 'local' or 'testnet'
VITE_DEFAULT_NETWORK=local

# Local Hardhat addresses (deterministic from Hardhat)
VITE_LOCAL_ORACLE_REGISTRY=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_LOCAL_MARKET_FACTORY=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# Sapphire Testnet addresses (fill in after deploying to testnet)
VITE_TESTNET_ORACLE_REGISTRY=
VITE_TESTNET_MARKET_FACTORY=
